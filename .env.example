# Embedding 模型 (阿里云百炼 DashScope)
DASHSCOPE_API_KEY=sk-e21fd71c617e4709b2ab4296f1ee776a

# =============================================================================
# 认证 (用户 + RBAC)
# =============================================================================
# JWT 签名密钥。生产请用: openssl rand -hex 32
YOUFU_JWT_SECRET=please-change-me-in-production-use-openssl-rand-hex-32
# 启动时自动创建的初始 admin 账号
YOUFU_ADMIN_USERNAME=admin
YOUFU_ADMIN_PASSWORD=admin-change-me-now
# Cookie Secure flag: 生产 (HTTPS) 设为 true; 本地 HTTP dev 设为 false
YOUFU_COOKIE_SECURE=false
# Access token 有效期 (小时) / Refresh token 有效期 (天)
YOUFU_SESSION_HOURS=24
YOUFU_REFRESH_DAYS=30
# bcrypt cost factor (12 是默认, 不要低于 10)
YOUFU_BCRYPT_ROUNDS=12